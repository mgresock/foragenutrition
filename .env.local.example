# Supabase — get from supabase.com > your project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server only — never expose

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Site URL — your production domain (used for Stripe redirects + reset links)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Rate limiting (Upstash Redis) — create a free DB at upstash.com > Redis.
# Without these the limiters no-op (fail-open) and the site is NOT rate limited.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Resend (transactional email: password reset, welcome) — resend.com
RESEND_API_KEY=re_your-key-here

# Stripe — dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_MONTHLY_PRICE_ID=price_xxx
STRIPE_YEARLY_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key

# Whoop (optional wearable integration) — developer.whoop.com
WHOOP_CLIENT_ID=your-whoop-client-id
WHOOP_CLIENT_SECRET=your-whoop-client-secret
WHOOP_REDIRECT_URI=https://yourdomain.com/api/whoop/callback
